    {
      "name": "Crear Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type es JSON\", () => {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response no está vacío\", () => {\r",
              "    pm.expect(pm.response.text().length).to.be.above(0);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "const booking = response.booking;\r",
              "\r",
              "pm.test(\"Existe bookingid\", () => {\r",
              "    pm.expect(response.bookingid).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"bookingid es numérico, entero y mayor a cero\", () => {\r",
              "    pm.expect(response.bookingid).to.be.a(\"number\");\r",
              "    pm.expect(Number.isInteger(response.bookingid)).to.be.true;\r",
              "    pm.expect(response.bookingid).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Existe objeto booking\", () => {\r",
              "    pm.expect(booking).to.exist;\r",
              "    pm.expect(booking).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Existen todos los campos del booking\", () => {\r",
              "    pm.expect(booking).to.have.property(\"firstname\");\r",
              "    pm.expect(booking).to.have.property(\"lastname\");\r",
              "    pm.expect(booking).to.have.property(\"totalprice\");\r",
              "    pm.expect(booking).to.have.property(\"depositpaid\");\r",
              "    pm.expect(booking).to.have.property(\"bookingdates\");\r",
              "    pm.expect(booking.bookingdates).to.have.property(\"checkin\");\r",
              "    pm.expect(booking.bookingdates).to.have.property(\"checkout\");\r",
              "    pm.expect(booking).to.have.property(\"additionalneeds\");\r",
              "});\r",
              "\r",
              "pm.test(\"Tipos de datos correctos\", () => {\r",
              "    pm.expect(booking.firstname).to.be.a(\"string\");\r",
              "    pm.expect(booking.lastname).to.be.a(\"string\");\r",
              "    pm.expect(booking.totalprice).to.be.a(\"number\");\r",
              "    pm.expect(booking.depositpaid).to.be.a(\"boolean\");\r",
              "    pm.expect(booking.bookingdates).to.be.an(\"object\");\r",
              "    pm.expect(booking.bookingdates.checkin).to.be.a(\"string\");\r",
              "    pm.expect(booking.bookingdates.checkout).to.be.a(\"string\");\r",
              "    pm.expect(booking.additionalneeds).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Valores retornados son correctos\", () => {\r",
              "    pm.expect(booking.firstname).to.eql(\"Thyara\");\r",
              "    pm.expect(booking.lastname).to.eql(\"Vintimilla\");\r",
              "    pm.expect(booking.totalprice).to.eql(145);\r",
              "    pm.expect(booking.depositpaid).to.eql(true);\r",
              "    pm.expect(booking.bookingdates.checkin).to.eql(\"2026-07-01\");\r",
              "    pm.expect(booking.bookingdates.checkout).to.eql(\"2026-07-08\");\r",
              "    pm.expect(booking.additionalneeds).to.eql(\"Desayuno\");\r",
              "});\r",
              "\r",
              "pm.test(\"Formato de fechas válido YYYY-MM-DD\", () => {\r",
              "    const regexFecha = /^\\d{4}-\\d{2}-\\d{2}$/;\r",
              "    pm.expect(booking.bookingdates.checkin).to.match(regexFecha);\r",
              "    pm.expect(booking.bookingdates.checkout).to.match(regexFecha);\r",
              "});\r",
              "\r",
              "pm.test(\"Checkout es posterior a checkin\", () => {\r",
              "    const checkin = new Date(booking.bookingdates.checkin);\r",
              "    const checkout = new Date(booking.bookingdates.checkout);\r",
              "\r",
              "    pm.expect(checkout > checkin).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"Tiempo de respuesta menor a 2000 ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.environment.set(\"bookingId\", response.bookingid);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
